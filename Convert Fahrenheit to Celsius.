#include <iostream>
using namespace std;

int main() {
    double fahrenheit, celsius;

    cout << "Enter temperature in Fahrenheit: ";
    cin >> fahrenheit;

    // Conversion formula
    celsius = (fahrenheit - 32) * 5 / 9;

    cout << fahrenheit << " Fahrenheit = " << celsius << " Celsius" << endl;

    return 0;
}
